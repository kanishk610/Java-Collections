import java.util.*;
class Main {
    public static void main(String[] args) {
        HashMap<Integer,String>color=new HashMap<>();
        color.put(1,"Red");
        color.put(2,"Blue");
        color.put(3,"Green");
        color.put(4,"Pink");
        color.put(5,"Black");
        
        for(Map.Entry x:color.entrySet()){
            System.out.println(x.getKey()+" "+x.getValue());
    }

    }
}
